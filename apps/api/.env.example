# Server
NODE_ENV=development
PORT=3001

# Database (local - docker-compose)
# DATABASE_URL is used by the running app and by Prisma Client
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/app?schema=public"

# DIRECT_URL is used by Prisma Migrate (migrate dev/deploy)
# Locally it's the same as DATABASE_URL (no connection pooler).
# In production (Supabase), DATABASE_URL points to the pooled connection
# (port 6543, pgbouncer) and DIRECT_URL to the direct connection (port 5432).
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/app?schema=public"

# Auth
JWT_SECRET="change-me"
JWT_EXPIRES_IN="1d"
JWT_REFRESH_SECRET="change-me-too"
JWT_REFRESH_EXPIRES_IN="30d"

# CORS
# Em dev: URL do Next
CORS_ORIGIN="http://localhost:3000"

# Admin user (created by seed script)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=

# Local
REDIS_URL=redis://localhost:6379
# Produção (Upstash) —

# Default API locale (fallback when Accept-Language is not sent)
API_LOCALE=pt
